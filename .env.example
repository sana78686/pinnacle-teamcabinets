APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
# Central Pinnacle admin (main app) — e.g. pinnacle.apimstec.com
CENTRAL_DOMAIN=pinnacle.apimstec.com
# Optional: comma-separated extra central hosts
# CENTRAL_DOMAINS=pinnacle.apimstec.com,www.pinnacle.apimstec.com

# Tenant wildcard base — tenants at {tenant-id}.apimstec.com (*.apimstec.com)
TENANT_DOMAIN=apimstec.com
# Legacy alias for TENANT_DOMAIN (optional if TENANT_DOMAIN is set)
APP_DOMAIN=apimstec.com

APP_URL=https://pinnacle.apimstec.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Default mailer — tenant subdomain emails (login OTP, orders, etc.)
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=no-reply@apimstec.com
MAIL_FROM_NAME="${APP_NAME}"
MAIL_EHLO_DOMAIN=apimstec.com
MAIL_REPLY_TO_ADDRESS=
MAIL_REPLY_TO_NAME="${APP_NAME}"

# Pinnacle super-admin INBOX — receives tenant registered, contact form, etc.
CENTRAL_MAIL=apimstecofficial@gmail.com
SUPERADMIN_EMAIL=superadmin@example.com
CENTRAL_MAIL_HOST=smtp.gmail.com
CENTRAL_MAIL_PORT=587
CENTRAL_MAIL_ENCRYPTION=tls
CENTRAL_MAIL_USERNAME=
CENTRAL_MAIL_PASSWORD=
CENTRAL_MAIL_FROM_ADDRESS=
CENTRAL_MAIL_FROM_NAME="Pinnacle"

STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
